# ============================================================
# XLMPredict Backend — Environment Variables
# Copy this file to .env and fill in the real values
# ============================================================

# --- Required ---

# PostgreSQL connection string (Neon or any PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Stellar admin wallet secret key (used to sign settle/cancel transactions)
ADMIN_SECRET_KEY=SXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Soroban smart contract ID on Stellar Testnet
CONTRACT_ID=CAZSI42RVHPPQBY3LKULN57R4EDPJKXDUXADXRMDCF4GDMVY7KLB2BBD

# Soroban RPC endpoint
RPC_URL=https://soroban-testnet.stellar.org

# Stellar network passphrase
NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# --- Optional (with defaults) ---

# Allowed CORS origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:5173

# Cron job interval in milliseconds (default: 60000 = 1 minute)
CRON_INTERVAL_MS=60000

# Price feed fetch interval in milliseconds (default: 30000 = 30 seconds)
PRICE_FETCH_INTERVAL_MS=30000

# Server port (default: 3001)
PORT=3001
